{
  "name": "mood-journal",
  "version": "1.0.4",
  "description": "Quickly log mood, activities, and notes to daily notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run test:run && npm run build",
    "version": "git add manifest.json versions.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.0",
    "typescript": "^5.8.0",
    "vitest": "4.1.10"
  }
}
